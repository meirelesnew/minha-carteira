rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Carteira/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /gastos/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /contratos/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /freelas/{doc} {
      allow read: if true;
      allow write: if true;
    }
    // Muth v2 — previsões da rede neural
    match /previsoes_carteira/{doc} {
      allow read: if true;
      allow write: if true;
    }
  }
}
