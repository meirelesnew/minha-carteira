rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leitura pública — qualquer um pode ver a vitrine
    match /Carteira/{doc} {
      allow read: if true;
      allow write: if true; // Simplificado — admin sem autenticação
    }
    match /gastos/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /contratos/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /freelas/{doc} {
      allow read: if true;
      allow write: if true;
    }
  }
}
